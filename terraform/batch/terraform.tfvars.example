# Copy to terraform.tfvars and fill in with values discovered from the live AWS resources
# (see README.md "Discovery"). terraform.tfvars is gitignored - it's environment-specific and
# may contain account-specific identifiers that shouldn't live in version control.

compute_environment_name = "TODO-discover-from-aws-batch-describe-compute-environments"
max_vcpus                = 0 # TODO
subnets                  = ["subnet-TODO"]
security_group_ids       = ["sg-TODO"]
job_queue_priority       = 1 # TODO - confirm against live queue

# ── Job definitions (ADR-0007) ──
# Surface every JD value at once from the live Fargate-runzi-opensha-JD:
#   aws batch describe-job-definitions --job-definition-name Fargate-runzi-opensha-JD \
#     --status ACTIVE --region us-east-1 \
#     --query 'jobDefinitions[0].containerProperties.{resourceRequirements:resourceRequirements, networkConfiguration:networkConfiguration, executionRoleArn:executionRoleArn, jobRoleArn:jobRoleArn, environment:environment}'
# Mapping: resourceRequirements VCPU entry -> default_vcpu, MEMORY entry (MiB) -> default_memory;
# networkConfiguration.assignPublicIp -> assign_public_ip (leave "" if there is no networkConfiguration).
# vcpu/memory are resting defaults (runzi overrides them per-job) but must be a valid Fargate pair.
image_repository   = "TODO-account.dkr.ecr.us-east-1.amazonaws.com/nzshm22/runzi" # no tag
execution_role_arn = "arn:aws:iam::TODO-account:role/toshi_batch_ECS_TaskExecution"
job_role_arn       = ""      # TODO - the live JD's jobRoleArn, or "" to omit
default_vcpu       = "8"     # TODO - resourceRequirements VCPU entry
default_memory     = "32768" # TODO - resourceRequirements MEMORY entry (MiB); must be valid for default_vcpu
assign_public_ip   = ""      # TODO - networkConfiguration.assignPublicIp (ENABLED/DISABLED), or "" if absent
# Env is split by toshi stage (ADR-0010): the :prod JDs authenticate to prod toshi, the :experimental
# JDs to test toshi. job_definition_environment holds only stage-agnostic vars shared by all four JDs;
# the toshi auth pair goes in the per-stage overlays below (merged over the shared base).
job_definition_environment = {
  # TODO - stage-agnostic entries from the live JD, e.g.:
  # NZSHM22_S3_UPLOAD_WORKERS = "5"
}
# :prod JDs -> PROD toshi. The external toshi_batch_ECS_TaskExecution role must be granted
# secretsmanager:GetSecretValue on this ARN, or :prod jobs fail auth at runtime.
prod_job_definition_environment = {
  # NZSHM22_TOSHI_M2M_SECRET_ARN = "arn:aws:secretsmanager:ap-southeast-2:TODO:secret:toshi-m2m-prod-..."
  # NZSHM22_TOSHI_COGNITO_DOMAIN = "https://toshi-TODO-prod.auth.ap-southeast-2.amazoncognito.com"
}
# :experimental JDs -> TEST toshi.
experimental_job_definition_environment = {
  # NZSHM22_TOSHI_M2M_SECRET_ARN = "arn:aws:secretsmanager:ap-southeast-2:TODO:secret:toshi-m2m-test-..."
  # NZSHM22_TOSHI_COGNITO_DOMAIN = "https://toshi-TODO-test.auth.ap-southeast-2.amazoncognito.com"
}

# ── EC2 compute environment, queue, and job definitions (ADR-0008, #322) ──
# Discover instance_role/maxvCpus/subnets/sgs from a WORKING EC2 compute environment before apply
# (copy the proven config; the EC2 side needs egress-capable subnets, NOT the Fargate ones):
#   aws batch describe-compute-environments --region us-east-1 \
#     --query 'computeEnvironments[?computeResources.type==`EC2`].{name:computeEnvironmentName, instanceRole:computeResources.instanceRole, maxvCpus:computeResources.maxvCpus, subnets:computeResources.subnets, sgs:computeResources.securityGroupIds}'
ec2_instance_role_arn = "arn:aws:iam::TODO-account:instance-profile/ecsInstanceRole" # TODO
ec2_max_vcpus         = 0                                                             # TODO - from the retired BigLever env's maxvCpus, or desired concurrency
# EC2 instances must reach the ECS/ECR endpoints to register, so they need their own egress-capable
# subnets + SG — the Fargate subnet is public with no NAT and works for Fargate only (assign_public_ip).
# Use the subnets/SG a working EC2 compute environment uses. Leave unset to (incorrectly) reuse the
# Fargate values.
ec2_subnets            = ["subnet-TODO"] # TODO - a working EC2 CE's subnets (NAT-capable / public-IP)
ec2_security_group_ids = ["sg-TODO"]     # TODO - a working EC2 CE's security group
# ec2_instance_types      = ["optimal"]              # default; instance-type tuning is #323
# ec2_min_vcpus           = 0                         # default; scale to zero when idle
# ec2_allocation_strategy = "BEST_FIT_PROGRESSIVE"    # default
# batch_service_role_arn  = ""                        # default: AWSServiceRoleForBatch service-linked role
# ec2_default_vcpu        = "8"                        # default resting value
# ec2_default_memory      = "32768"                   # default resting value (MiB)
